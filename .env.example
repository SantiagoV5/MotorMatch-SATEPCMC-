# ─────────────────────────────────────────────────────────────────────────────
# .env.example - Plantilla de variables de entorno
# ─────────────────────────────────────────────────────────────────────────────
# 
# Copia este archivo a .env y completa los valores reales
# NUNCA commits .env al repositorio - solo .env.example
#

# ═════════════════════════════════════════════════════════════════════════════
# ENTORNO
# ═════════════════════════════════════════════════════════════════════════════
NODE_ENV=development

# ═════════════════════════════════════════════════════════════════════════════
# BASE DE DATOS - SUPABASE
# ═════════════════════════════════════════════════════════════════════════════
# 
# Obtén estas URLs de:
#   1. Ve a https://supabase.com
#   2. Abre tu proyecto
#   3. Settings → Database → Connection string
#   4. Copia las dos URLs (con y sin pooler)
#
# DATABASE_URL: usa "Connection Pooler" (puerto 6543) - para queries normales
# DIRECT_URL: usa "Direct" (puerto 5432) - para migraciones Prisma
#
DATABASE_URL="postgresql://postgres.YOUR_PROJECT:YOUR_PASSWORD@aws-0-REGION.pooler.supabase.com:6543/postgres?pgbouncer=true&sslmode=require"
DIRECT_URL="postgresql://postgres.YOUR_PROJECT:YOUR_PASSWORD@aws-0-REGION.pooler.supabase.com:5432/postgres?sslmode=require"

# ═════════════════════════════════════════════════════════════════════════════
# JWT - AUTENTICACIÓN
# ═════════════════════════════════════════════════════════════════════════════
# 
# Genera un JWT_SECRET seguro con:
#   node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
#
JWT_SECRET=tu_jwt_secreto_muy_largo_y_aleatorio_reemplaza_esto_66_caracteres_minimo
JWT_EXPIRES_IN=7d

# ═════════════════════════════════════════════════════════════════════════════
# APLICACIÓN
# ═════════════════════════════════════════════════════════════════════════════
FRONTEND_URL=http://localhost
APP_URL=http://localhost

# ═════════════════════════════════════════════════════════════════════════════
# EMAIL - SMTP (Opcional - deja en blanco para desarrollo sin email)
# ═════════════════════════════════════════════════════════════════════════════
# 
# Para usar Gmail:
#   1. Activa verificación en 2 pasos en tu cuenta Google
#   2. Ve a: https://myaccount.google.com/apppasswords
#   3. Genera una "App Password"
#   4. Copia el resultado como SMTP_PASS
#
# Para Mailtrap (pruebas gratuitas):
#   1. Ve a https://mailtrap.io
#   2. Obtén credenciales
#   3. Reemplaza SMTP_HOST, SMTP_PORT, SMTP_USER, SMTP_PASS
#
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=tu_email@gmail.com
SMTP_PASS=tu_app_password_16_caracteres

# ═════════════════════════════════════════════════════════════════════════════
# PostgreSQL LOCAL (Solo si usas BD local en Docker)
# ═════════════════════════════════════════════════════════════════════════════
POSTGRES_PASSWORD=postgres_dev_password
