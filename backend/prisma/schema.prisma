generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

// ─── USUARIOS ────────────────────────────────────────────────────────────────
model User {
  id                 Int             @id @default(autoincrement())
  email              String          @unique @db.VarChar(255)
  passwordHash       String?         @map("password_hash") @db.VarChar(255)
  fullName           String          @map("full_name") @db.VarChar(200)
  phone              String?         @db.VarChar(20)
  birthDate          DateTime?       @map("birth_date") @db.Date
  city               String?         @db.VarChar(100)
  heightCm           Int?            @map("height_cm")
  weightKg           Decimal?        @map("weight_kg") @db.Decimal(5, 2)
  ridingExperience   String?         @map("riding_experience") @db.VarChar(20)
  preferredBrands    String[]        @map("preferred_brands")
  budgetRange        Json?           @map("budget_range")
  isActive              Boolean         @default(true) @map("is_active")
  emailVerified         Boolean         @default(false) @map("email_verified")
  verificationToken     String?         @unique @map("verification_token")
  verificationExpiresAt DateTime?       @map("verification_expires_at")
  lastLogin             DateTime?       @map("last_login")
  createdAt             DateTime        @default(now()) @map("created_at")
  updatedAt             DateTime        @updatedAt @map("updated_at")

  questionnaires     Questionnaire[]
  recommendations    Recommendation[]

  @@map("users")
}

// ─── MOTOCICLETAS ─────────────────────────────────────────────────────────────
model Motorcycle {
  id                    Int       @id @default(autoincrement())
  brand                 String    @db.VarChar(50)
  model                 String    @db.VarChar(100)
  year                  Int?
  engineCc              Int?      @map("engine_cc")
  engineType            String?   @map("engine_type") @db.VarChar(50)
  powerHp               Decimal?  @map("power_hp") @db.Decimal(6, 2)
  torqueNm              Decimal?  @map("torque_nm") @db.Decimal(6, 2)
  weightKg              Decimal?  @map("weight_kg") @db.Decimal(8, 2)
  seatHeightCm          Int?      @map("seat_height_cm")
  fuelType              String?   @map("fuel_type") @db.VarChar(30)
  fuelTankLiters        Decimal?  @map("fuel_tank_liters") @db.Decimal(5, 2)
  consumptionKmpl       Decimal?  @map("consumption_kmpl") @db.Decimal(5, 2)
  transmission          String?   @db.VarChar(30)
  brakeSystem           String?   @map("brake_system") @db.VarChar(50)
  price                 Decimal?  @db.Decimal(12, 2)
  currency              String?   @default("COP") @db.VarChar(10)
  soatEstimated         Decimal?  @map("soat_estimated") @db.Decimal(10, 2)
  registrationEstimated Decimal?  @map("registration_estimated") @db.Decimal(10, 2)
  imageUrl              String?   @map("image_url")
  galleryImages         Json?     @map("gallery_images")
  description           String?
  advantages            String[]
  disadvantages         String[]
  colors                String[]  @default([])
  warranty              String?   @db.VarChar(200)
  countryOrigin         String?   @map("country_origin") @db.VarChar(100)
  source                String?   @db.VarChar(50)
  externalIds           Json?     @map("external_ids")
  lastApiUpdate         DateTime? @map("last_api_update")
  isActive              Boolean   @default(true) @map("is_active")
  createdAt             DateTime  @default(now()) @map("created_at")
  updatedAt             DateTime  @updatedAt @map("updated_at")

  recommendations       Recommendation[]

  @@map("motorcycles")
}

// ─── CUESTIONARIOS ────────────────────────────────────────────────────────────
model Questionnaire {
  id                   Int       @id @default(autoincrement())
  userId               Int?      @map("user_id")
  budget               Decimal   @db.Decimal(12, 2)
  includesSoat         Boolean   @default(false) @map("includes_soat")
  includesRegistration Boolean   @default(false) @map("includes_registration")
  usageType            String    @map("usage_type") @db.VarChar(30)
  frequency            String?   @db.VarChar(30)
  hasPassenger         Boolean   @default(false) @map("has_passenger")
  passengerFrequency   String?   @map("passenger_frequency") @db.VarChar(20)
  heightCm             Int       @map("height_cm")
  weightKg             Decimal?  @map("weight_kg") @db.Decimal(5, 2)
  comfortWithHeavy     Boolean?  @map("comfort_with_heavy")
  recommendationIds    Int[]     @map("recommendation_ids")
  completedAt          DateTime  @default(now()) @map("completed_at")
  createdAt            DateTime  @default(now()) @map("created_at")

  user                 User?           @relation(fields: [userId], references: [id], onDelete: Cascade)
  recommendations      Recommendation[]

  @@map("questionnaires")
}

// ─── RECOMENDACIONES ──────────────────────────────────────────────────────────
model Recommendation {
  id                 Int        @id @default(autoincrement())
  userId             Int?       @map("user_id")
  motorcycleId       Int?       @map("motorcycle_id")
  compatibilityScore Int        @map("compatibility_score")
  questionnaireId    Int?       @map("questionnaire_id")
  reasons            Json       @default("[]")
  warnings           String[]   @default([])
  isSaved            Boolean    @default(false) @map("is_saved")
  viewedAt           DateTime?  @map("viewed_at")
  savedAt            DateTime?  @map("saved_at")
  createdAt          DateTime   @default(now()) @map("created_at")

  user               User?          @relation(fields: [userId], references: [id], onDelete: Cascade)
  motorcycle         Motorcycle?    @relation(fields: [motorcycleId], references: [id], onDelete: Cascade)
  questionnaire      Questionnaire? @relation(fields: [questionnaireId], references: [id])

  @@unique([userId, motorcycleId, questionnaireId], name: "unique_recommendation")
  @@map("recommendations")
}
