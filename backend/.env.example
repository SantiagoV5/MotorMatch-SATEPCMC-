# ─── Servidor ─────────────────────────────────────────────────────────────────
NODE_ENV=development
PORT=3000

# ─── PostgreSQL (Supabase) ────────────────────────────────────────────────────
# DATABASE_URL: connection pooler (puerto 6543) — para queries en runtime
# DIRECT_URL:   conexión directa (puerto 5432)  — para `prisma db push`
#
# Cómo obtener estas URLs en Supabase:
#   Project Settings → Database → Connection string → URI
#   (marca "Use connection pooling" para DATABASE_URL)
DATABASE_URL="postgresql://postgres.PROYECTO:CONTRASEÑA@aws-0-REGION.pooler.supabase.com:6543/postgres?pgbouncer=true&sslmode=require"
DIRECT_URL="postgresql://postgres.PROYECTO:CONTRASEÑA@aws-0-REGION.pooler.supabase.com:5432/postgres?sslmode=require"

# ─── JWT ───────────────────────────────────────────────────────────────────────
# Genera un secreto seguro con:
#   node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=reemplaza_esto_con_un_secreto_muy_largo_y_aleatorio
JWT_EXPIRES_IN=7d

# ─── App ───────────────────────────────────────────────────────────────────────
# URL pública del frontend (usada para construir el enlace de verificación)
APP_URL=http://localhost:5173

# ─── Email (SMTP) ──────────────────────────────────────────────────────────────
# Si SMTP_USER o SMTP_PASS están vacíos, el enlace de verificación se imprime
# en la terminal del backend (útil para desarrollo sin configurar email).
#
# Opción 1 — Gmail con App Password:
#   1. Activa la verificación en 2 pasos en tu cuenta Google.
#   2. Ve a: Cuenta Google → Seguridad → Contraseñas de aplicaciones.
#   3. Genera una contraseña de 16 caracteres y úsala como SMTP_PASS.
#
# Opción 2 — Mailtrap (pruebas, gratis): https://mailtrap.io
#   SMTP_HOST=sandbox.smtp.mailtrap.io  SMTP_PORT=2525
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=tucorreo@gmail.com
SMTP_PASS=tu_app_password_16_caracteres
