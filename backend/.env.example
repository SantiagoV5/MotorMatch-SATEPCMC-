# ─── Servidor ─────────────────────────────────────────────────────────────────
NODE_ENV=development
PORT=3000

# ─── PostgreSQL ────────────────────────────────────────────────────────────────
# Opciones de hosting: Supabase (gratis), Railway, Neon, o local con Docker
# Formato: postgresql://USUARIO:PASSWORD@HOST:PUERTO/NOMBRE_DB
DATABASE_URL="postgresql://postgres:password@localhost:5432/motormatch_db"

# ─── JWT (Autenticación propia) ────────────────────────────────────────────────
# JWT_SECRET: cadena aleatoria larga y secreta. Generar con:
#   node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
# NUNCA subir el valor real al repositorio.
JWT_SECRET=reemplaza_esto_con_un_secreto_muy_largo_y_aleatorio
JWT_EXPIRES_IN=7d
